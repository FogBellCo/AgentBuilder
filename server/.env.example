# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# OpenAI model name (optional, defaults to gpt-5.2)
OPENAI_MODEL=gpt-5.2

# TritonAI webhook URL for submission forwarding (optional)
WEBHOOK_URL=https://...

# Backend server port (optional, defaults to 3001)
PORT=3001

# Allowed CORS origin for frontend (optional, defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
